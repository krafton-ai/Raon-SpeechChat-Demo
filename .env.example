# =============================================================================
# Raon SpeechChat Demo — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Model (auto-download or manual)
# ---------------------------------------------------------------------------

# Option A: Leave MODEL_PATH empty to auto-download from HuggingFace.
# The model is cached in a Docker volume and reused on subsequent runs.
# MODEL_PATH=

# Option B: Point to a pre-downloaded SGLang bundle to skip download.
# MODEL_PATH=/path/to/your/sglang-bundle

# HuggingFace model ID for auto-download (default: KRAFTON/Raon-SpeechChat-9B)
# HF_MODEL_ID=KRAFTON/Raon-SpeechChat-9B

# HuggingFace token (only needed for gated models)
# HF_TOKEN=hf_your_token_here

# ---------------------------------------------------------------------------
# GPU Configuration
# ---------------------------------------------------------------------------

# Comma-separated GPU IDs to use (default: 0)
# FD_GPU_IDS=0

# Maximum concurrent sessions per GPU (default: 2)
# FD_MAX_SESSIONS_PER_GPU=2

# ---------------------------------------------------------------------------
# Speaker Conditioning (optional)
# ---------------------------------------------------------------------------

# Path to reference speaker WAV file (24kHz mono)
# DEFAULT_SPEAKER_AUDIO_PATH=/app/Raon-SpeechChat-Demo/data/raon.wav

# Label for the default speaker embedding
# DEFAULT_SPEAKER_LABEL=raon_f_fixed

# Path to pre-computed speaker embedding (.pt file)
# DEFAULT_SPEAKER_EMBEDDING_PATH=

# ---------------------------------------------------------------------------
# Performance Tuning (optional)
# ---------------------------------------------------------------------------

# Enable torch.compile for audio encoder/decoder modules (0 or 1, default: 1)
# FD_ENABLE_COMPILE_AUDIO_MODULES=1

# Max decode frames per inference call (default: 1)
# FD_MAX_DECODE_FRAMES_PER_CALL=1

# ---------------------------------------------------------------------------
# SpeechBrain Cache (optional)
# ---------------------------------------------------------------------------

# Directory for caching SpeechBrain ECAPA-TDNN model files
# SPEECHBRAIN_ECAPA_SAVEDIR=/tmp/speechbrain_ecapa_cache

# ---------------------------------------------------------------------------
# Gateway (optional)
# ---------------------------------------------------------------------------

# Gateway listen host and port
# FD_GW_HOST=0.0.0.0
# FD_GW_PORT=8080
